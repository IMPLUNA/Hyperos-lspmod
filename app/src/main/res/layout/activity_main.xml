<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HyperOS 状态栏增强模块"
        android:textSize="20sp"
        android:layout_marginBottom="20dp"/>

    <Switch
        android:id="@+id/switch_triple_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="启用三排状态栏"/>

    <Switch
        android:id="@+id/switch_color_notify"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="通知卡片自动着色"/>

    <Switch
        android:id="@+id/switch_weather"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示天气"/>

    <Switch
        android:id="@+id/switch_net_speed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示实时网速"/>

    <Switch
        android:id="@+id/switch_signal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示信号强度"/>

    <Switch
        android:id="@+id/switch_bat_temp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示电池温度"/>

    <Switch
        android:id="@+id/switch_cpu_temp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示CPU温度"/>

    <Switch
        android:id="@+id/switch_current"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示充电电流"/>

    <Switch
        android:id="@+id/switch_power"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示实时功耗"/>

    <Switch
        android:id="@+id/switch_deco_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示装饰文字"/>

    <!-- 日志区域标题和刷新按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="运行日志"
            android:textSize="16sp" />
        <Button
            android:id="@+id/btn_refresh_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="刷新" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="#F0F0F0">
        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textSize="12sp"
            android:textColor="#000000"
            android:typeface="monospace"
            android:gravity="start"
            android:text="日志加载中..." />
    </ScrollView>

</LinearLayout>
