<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="HyperOS Mod"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 传统 Xposed 入口（兼容旧版框架） -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposedminversion"
            android:value="93" />
        <meta-data
            android:name="xposedinit"
            android:value="com.colored.notifications.LegacyHook" />

        <!-- 新版 API 101 模块入口 -->
        <meta-data
            android:name="xposedmoduleclass"
            android:value="com.colored.notifications.XposedInit" />
        <meta-data
            android:name="xposeddescription"
            android:value="HyperOS Status Bar and Notification Mod" />
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

    </application>
</manifest>
